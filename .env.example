# ============================================================================
# OmniAgent LLM Configuration
# Copy this file to .env and fill in your actual values
# ============================================================================

# LLM Provider Selection
# Options: "gemini", "openai", "groq", "ollama", "huggingface_local", "huggingface_cloud"
LLM_PROVIDER=gemini

# LLM Temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.6

# ============================================================================
# Google Gemini Configuration
# Get API key: https://aistudio.google.com/app/apikeys
# ============================================================================
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# OpenAI Configuration
# Get API key: https://platform.openai.com/api-keys
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Groq Configuration
# Get API key: https://console.groq.com/keys
# ============================================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# Ollama Configuration (Local Inference)
# Install from: https://ollama.ai
# Run with: ollama serve
# ============================================================================
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# HuggingFace Configuration
# Get API key: https://huggingface.co/settings/tokens
# ============================================================================
# For cloud-based inference (huggingface_cloud):
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# For local inference (huggingface_local):
HF_DEVICE=cpu  # "cpu" or "cuda"
HF_LOCAL_REPO=./models/huggingface  # Directory to cache models

# ============================================================================
# External Services & Tools Configuration
# ============================================================================

# Tavily Search API
# For web search integration in research tasks
# Get API key: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# SerpAPI (Google Search)
# For enhanced search capabilities
# Get API key: https://serpapi.com
SERPAPI_API_KEY=your_serpapi_api_key_here

# LangSmith (LangChain Observability)
# For monitoring and debugging LangChain operations
# Get API key: https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here

# ============================================================================
# Other OmniAgent Configuration
# ============================================================================
OMNIAGENT_DATA_DIR=~/.local/share/omniagent
CHECKPOINT_BACKEND=sqlite
